# Database
DATABASE_URL=postgresql://user:password@localhost:5432/autopilot
POSTGRES_USER=autopilot_user
POSTGRES_PASSWORD=changeme
POSTGRES_DB=autopilot

# API Configuration
NEXT_PUBLIC_API_URL=/api

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRY=7d

# Environment
NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000
CRON_SECRET=replace_with_a_long_random_secret
FROM_EMAIL=noreply@autopilot.app
RESEND_API_KEY=

# Creator Platform Integration (Orisae)
NEXT_PUBLIC_ORISAE_URL=https://orisae-main.vercel.app
ORISAE_API_KEY=optional_integration_key

# Base Blockchain
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org
BASE_CONTRACT_ADDRESS=0x
PRIVATE_KEY_FOR_SIGNING=

# Features
ENABLE_DESKTOP_APP=true
ENABLE_NOTIFICATIONS=true
ENABLE_WEBHOOK_TRACKING=true
